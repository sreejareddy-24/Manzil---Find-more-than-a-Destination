# Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/careermate?schema=public

# Supabase
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# OpenRouter (fallback AI)
OPENROUTER_API_KEY=your_openrouter_api_key

# Tavily Search API
TAVILY_API_KEY=your_tavily_api_key

# WhatsApp Cloud API
WHATSAPP_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_custom_verify_token_string
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# Encryption
ENCRYPTION_KEY=your_32_char_encryption_key_here!!

# Cron Schedules (cron syntax)
OPPORTUNITY_SEARCH_CRON=0 */6 * * *
MATCH_NOTIFY_CRON=0 9 * * *
CLEANUP_CRON=0 2 * * *

# Copy this file to .env (inside backend/) and fill in real values.

# Get this from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

# Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project-ref.supabase.co
# IMPORTANT: this is the SERVICE ROLE key (not the anon key) — it bypasses RLS
# so the backend can write trips/itinerary rows on the user's behalf.
# Keep it server-side only, never ship it to the frontend.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Used for CORS — set to your frontend's dev/prod URL
FRONTEND_ORIGIN=http://localhost:5173
